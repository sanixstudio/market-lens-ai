# Clerk (optional in development — keyless mode can supply temp keys; see https://clerk.com/docs/nextjs/getting-started/quickstart)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# PostgreSQL connection (local Docker: postgresql://postgres:postgres@localhost:5432/marketlens)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketlens

# OpenAI for market explanations (optional — template fallback if unset)
OPENAI_API_KEY=

# Model for explanations
OPENAI_MODEL=gpt-4o-mini

# Mapbox GL (react-map-gl/mapbox). Exposed to the browser as NEXT_PUBLIC_*.
# @see https://visgl.github.io/react-map-gl/docs/get-started/mapbox-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=

# Remotive ingest (optional — no API key; see scripts/ingest-remotive.ts)
# After pulling schema changes, run: npm run db:migrate
# REMOTIVE_CATEGORY=software-dev
# REMOTIVE_LIMIT=200

# Synthetic seed volume (optional — see scripts/seed.ts; default 6, max 40)
# SEED_SCALE=6
